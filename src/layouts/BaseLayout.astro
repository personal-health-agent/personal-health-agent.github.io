---
import '../styles/global.css';
import { getEntry } from 'astro:content';
import { withBase } from '../utils/url';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const courseEntry = await getEntry('course', 'course');
const courseData = courseEntry!.data;

const finalDescription =
  description ?? courseData.title; // BaseLayout no longer needs the long body for meta tags

// Use the short name (not a single course number) so neither cross-listing is privileged.
const shortName = courseData.shortName ?? courseData.code;
const fullTitle = title ? `${title} · ${shortName}` : shortName;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="description" content={finalDescription} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={withBase('/og-image.svg')} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
